{
  "name": "agent-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Deck — macOS 软件 Agent 操作台（ZCode + Codex）",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm dev:desktop",
    "build": "pnpm --filter @agent-deck/desktop build",
    "typecheck": "pnpm --filter @agent-deck/desktop typecheck",
    "test": "pnpm test:rust",
    "test:e2e": "pnpm test:rust:e2e",
    "dev:desktop": "pnpm --filter @agent-deck/desktop tauri dev",
    "build:desktop": "pnpm --filter @agent-deck/desktop tauri build",
    "test:rust": "cargo test --workspace --exclude agent-deck-desktop",
    "test:rust:e2e": "cargo test -p agent-deck-host-core --tests"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
