{
  "name": "agent-deck",
  "version": "0.1.0",
  "private": true,
  "description": "Agent Deck — 跨工具的 agent 状态牌（ZCode + Codex）",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm dev:desktop",
    "dev:host": "pnpm --filter @agent-deck/host dev",
    "dev:sim": "pnpm --filter @agent-deck/simulator dev",
    "test": "pnpm test:rust",
    "test:unit": "pnpm -r --filter @agent-deck/host test:unit",
    "test:e2e": "pnpm test:rust:e2e",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "verify": "pnpm --filter @agent-deck/host verify",
    "dev:desktop": "pnpm --filter @agent-deck/desktop tauri dev",
    "build:desktop": "pnpm --filter @agent-deck/desktop tauri build",
    "test:rust": "cargo test --workspace --exclude agent-deck-desktop",
    "test:rust:e2e": "cargo test -p agent-deck-host-core --tests",
    "test:legacy": "pnpm -r --filter @agent-deck/host test",
    "test:legacy:e2e": "pnpm -r --filter @agent-deck/host test:e2e",
    "dev:legacy": "concurrently -n host,sim -c blue,green -k \"pnpm --filter @agent-deck/host dev\" \"pnpm --filter @agent-deck/simulator dev\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "concurrently": "^10.0.3",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
