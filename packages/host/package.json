{
  "name": "@agent-deck/host",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "bin": {
    "agent-deck-host": "./src/main.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir test --exclude '**/e2e/**'",
    "test:e2e": "vitest run --dir test/e2e",
    "verify": "tsx scripts/verify.ts"
  },
  "dependencies": {
    "@agent-deck/protocol": "workspace:*",
    "better-sqlite3": "^11.5.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
